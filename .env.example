DATABASE_URL=sqlite:///./app.db
SECRET_KEY=supersecret

# Fernet encryption key — BOTH backend and stylometry-ml-service MUST share the same value.
# Generate a valid key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to use an ephemeral dev key (ciphertexts will be lost on restart).
ENCRYPTION_KEY=
