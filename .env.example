# =============================================================================
# Thai-Stylometry Chat — Root Environment Variables (Docker Compose)
# =============================================================================

# ----------------------------------------------------------------------------
# Backend database URL
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./app.db

# ----------------------------------------------------------------------------
# JWT signing secret (REQUIRED)
# Generate with:
#   openssl rand -hex 32
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=

# Optional legacy alias for old backend code paths. Keep empty unless needed.
SECRET_KEY=

# ----------------------------------------------------------------------------
# Fernet encryption key (REQUIRED)
# MUST be identical for backend and stylometry-ml-service.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ----------------------------------------------------------------------------
ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Backend CORS allow list
# Comma-separated origins. Use exact scheme + host (+ port if non-standard).
# Example for Droplet IP + local fallback:
# ALLOW_ORIGINS=http://your-droplet-ip,http://your-droplet-ip:80,http://localhost:5173
# ----------------------------------------------------------------------------
ALLOW_ORIGINS=*

# Optional backward-compat alias (backend supports both):
ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# Frontend runtime API/WS endpoints (exposed to browser by Vite)
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Optional backward-compat aliases (frontend supports both):
VITE_API_BASE=
VITE_WS_BASE=

# ----------------------------------------------------------------------------
# External frontend port for Docker Compose mapping (${FRONTEND_PORT}:5173)
# Set to 80 for production, or 5173 for local/dev preference.
# ----------------------------------------------------------------------------
FRONTEND_PORT=80
