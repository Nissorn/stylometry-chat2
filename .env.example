# =============================================================================
# Thai-Stylometry Chat — Root Environment Variables (Docker Compose)
# =============================================================================

# ----------------------------------------------------------------------------
# Backend database URL
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./app.db

# ----------------------------------------------------------------------------
# JWT signing secret (REQUIRED)
# Generate with:
#   openssl rand -hex 32
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=

# Optional legacy alias for old backend code paths. Keep empty unless needed.
SECRET_KEY=

# ----------------------------------------------------------------------------
# Fernet encryption key (REQUIRED)
# MUST be identical for backend and stylometry-ml-service.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ----------------------------------------------------------------------------
ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Backend CORS allow list
# Comma-separated origins. Use exact scheme + host (+ port if non-standard).
# Example for deployed domain + local fallback:
# ALLOW_ORIGINS=https://stylometry.nissorn.codes,http://localhost:5173
# ----------------------------------------------------------------------------
ALLOW_ORIGINS=https://stylometry.nissorn.codes

# Optional backward-compat alias (backend supports both):
ALLOWED_ORIGINS=https://stylometry.nissorn.codes,http://stylometry.nissorn.codes

# ----------------------------------------------------------------------------
# Frontend runtime API/WS endpoints (exposed to browser by Vite)
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=https://stylometry.nissorn.codes
VITE_WS_BASE_URL=wss://stylometry.nissorn.codes

# Optional backward-compat aliases (frontend supports both):
VITE_API_BASE=
VITE_WS_BASE=

# Optional deployment documentation value
PUBLIC_DOMAIN=stylometry.nissorn.codes
