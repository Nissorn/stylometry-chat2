# =============================================================================
# Thai-Stylometry Chat — Frontend Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# Vite exposes variables prefixed with VITE_ to browser code via:
#   import.meta.env.VITE_API_BASE
#
# For local development the defaults below work out of the box.
# For a DigitalOcean Droplet deployment, replace localhost with your
# Droplet's public IP address or domain name.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API base URL
# Used by all fetch() calls in App.svelte and Sidebar.svelte.
#
# Local dev:    http://localhost:8000
# Production:   http://your-droplet-ip:8000
#               https://api.yourdomain.com   (if behind a reverse proxy)
# -----------------------------------------------------------------------------
VITE_API_BASE=http://localhost:8000

# -----------------------------------------------------------------------------
# Backend WebSocket base URL
# Used by connectWebSocket() in App.svelte.
#
# Local dev:    ws://localhost:8000
# Production:   ws://your-droplet-ip:8000
#               wss://api.yourdomain.com   (if behind TLS/nginx)
#
# Note: If your domain uses HTTPS, you MUST use wss:// here or browsers
# will block the mixed-content WebSocket connection.
# -----------------------------------------------------------------------------
VITE_WS_BASE=ws://localhost:8000
